# ─────────────────────────────────────────────────────────────────────────────
# NESTfetch secrets (Phase 4) — copy to  .env  and fill in.
# .env is git-ignored. These take precedence over config.yaml (but real
# environment variables still win over .env).
# ─────────────────────────────────────────────────────────────────────────────

# --- Telegram (get a bot token from @BotFather) ---
NESTFETCH_TELEGRAM_ENABLED=false
NESTFETCH_TELEGRAM_TOKEN=
NESTFETCH_TELEGRAM_CHAT_ID=

# --- Discord (Server Settings → Integrations → Webhooks) ---
NESTFETCH_DISCORD_ENABLED=false
NESTFETCH_DISCORD_WEBHOOK_URL=

# --- Email (SMTP) ---
NESTFETCH_EMAIL_ENABLED=false
NESTFETCH_EMAIL_SMTP_HOST=smtp.gmail.com
NESTFETCH_EMAIL_SMTP_PORT=587
NESTFETCH_EMAIL_USERNAME=
NESTFETCH_EMAIL_PASSWORD=
NESTFETCH_EMAIL_FROM=
NESTFETCH_EMAIL_TO=you@example.com
NESTFETCH_EMAIL_USE_TLS=true

# --- Which events trigger a notification ---
NESTFETCH_NOTIFY_ON_NEW_GAMES=true
NESTFETCH_NOTIFY_ON_DEAD_LINKS=true

# --- Scheduler (--watch) defaults ---
NESTFETCH_SCHEDULE_TASK=both
NESTFETCH_SCHEDULE_INTERVAL_MINUTES=60
