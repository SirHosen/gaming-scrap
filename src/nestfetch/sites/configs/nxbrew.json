{
  "name": "nxbrew",
  "base_url": "https://nxbrew.me/",
  "category": "switch-rom",
  "platform": "Nintendo Switch",
  "description": "NXBrew — Nintendo Switch NSP/XCI/NSZ downloads (onclick gate).",
  "listing": {
    "first_page_url": "{base}",
    "page_url": "{base}page/{page}/",
    "search_first_url": "{base}?s={query}",
    "search_url": "{base}page/{page}/?s={query}",
    "item": "article.hitmag-post",
    "fields": {
      "title": [
        "h3.entry-title a",
        "h2.entry-title a",
        "h3 a"
      ],
      "detail_url": {
        "selector": [
          "h3.entry-title a",
          "h3 a"
        ],
        "attr": "href",
        "transform": [
          "absolute_url"
        ]
      }
    }
  },
  "detail": {
    "mirror_item": "button.nsp-download, a.nsp-download",
    "mirror_fields": {
      "redirect_url": {
        "attr": "onclick",
        "regex": "window\\.open\\('([^']+)'",
        "regex_group": 1
      },
      "hoster": {
        "attr": "onclick",
        "regex": "window\\.open\\('https?://([^/?']+)",
        "regex_group": 1,
        "transform": [
          "upper"
        ]
      }
    },
    "title": [
      {
        "selector": "meta[property='og:title']",
        "attr": "content"
      },
      "h1.entry-title",
      "h1"
    ]
  },
  "resolve": {
    "mode": "none"
  }
}
