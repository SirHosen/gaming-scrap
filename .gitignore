# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ── Virtual environments ────────────────────────────────
.venv/
venv/
env/
ENV/

# ── NESTfetch runtime output ────────────────────────────
output/
*.log

# Scraped data (don't commit large/generated data dumps)
*.csv
*.json
!requirements*.txt
# ...but the shipped site configs ARE part of the package
!src/nestfetch/sites/configs/
!src/nestfetch/sites/configs/*.json

# ── Secrets / config ────────────────────────────────────
.env
.env.*
!.env.example
config.yaml
config.yml
config.json
config.local.py
*.secret
# ...but keep the sample templates in the repo
!config.example.yaml

# ── Tooling caches ──────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Editors / OS ────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
